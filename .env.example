# ============================================================
# DATA PLATFORM POC - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in values
# NEVER commit .env to Git - it is in .gitignore
# ============================================================

# --- NETWORK ---
PRIMARY_NODE_IP=192.168.0.10
SECONDARY_NODE_IP=192.168.0.11
NAS_IP=192.168.0.20

# --- MINIO (S3-compatible storage) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_minimum_12_chars
MINIO_ENDPOINT=http://192.168.0.10:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# --- KAFKA ---
KAFKA_BROKER=192.168.0.10:9092
KAFKA_ZOOKEEPER=192.168.0.10:2181

# --- SPARK ---
SPARK_MASTER=spark://192.168.0.10:7077
SPARK_WORKER_MEMORY=8g
SPARK_WORKER_CORES=4

# --- AIRFLOW ---
AIRFLOW_FERNET_KEY=changeme_generate_with_python
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme
AIRFLOW_ADMIN_EMAIL=your@email.com
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow

# --- SCHEMA REGISTRY ---
SCHEMA_REGISTRY_DB_URL=postgresql+psycopg2://schema_registry:changeme@localhost:5432/schema_registry
SCHEMA_REGISTRY_PORT=8000

# --- LLM API (AI Query Layer) ---
ANTHROPIC_API_KEY=changeme
LLM_MODEL=claude-sonnet-4-6

# --- POSTGRES ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=changeme
POSTGRES_DB=platform
